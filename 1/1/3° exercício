<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora</title>
</head>
<body>

<input type="number" id="n1" placeholder="Diga o primeiro número">

<select id="operacao">
    <option value="1">-</option>
    <option value="2">+</option>
    <option value="3">/</option>
    <option value="4">*</option>
</select>

<input type="number" id="n2" placeholder="Diga o segundo número">

<button id="resultado">Resultado</button>

<p id="resposta"></p>

<script>

const n1 = document.getElementById("n1")
const n2 = document.getElementById("n2")
const operacao = document.getElementById("operacao")
const botao = document.getElementById("resultado")
const resposta = document.getElementById("resposta")

botao.addEventListener("click", function(){

    let valor1 = Number(n1.value)
    let valor2 = Number(n2.value)
    let resultado

    if(operacao.value == "1"){
        resultado = valor1 - valor2
    }
    else if(operacao.value == "2"){
        resultado = valor1 + valor2
    }
    else if(operacao.value == "3"){
        resultado = valor1 / valor2
    }
    else if(operacao.value == "4"){
        resultado = valor1 * valor2
    }

    resposta.textContent = "Resultado: " + resultado

})

</script>

</body>
</html>
